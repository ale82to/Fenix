{
  "manifest_version": 2,
  "browser_specific_settings": {
    "gecko": {
      "id": "ads@mozac.org"
    }
  },
  "name": "Mozilla Android Components - Ads Telemetry",
  "version": "${version}",
  "content_scripts": [
    {
      "matches": ["https://www.baidu99.com/*"],
      "include_globs": [
        
        "https://www.baidu99.com/*",
        "https://m.baidu.com/*"
      ],
      "js": ["adsTelemetry.js"],
      "run_at": "document_end"
    }
  ],
  "permissions": [
    "geckoViewAddons",
    "nativeMessaging",
    "nativeMessagingFromContent"
  ]
}
